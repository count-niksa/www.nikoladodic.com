---
const education = [
  {
    institution: "Singidunum University",
    degree: "Master of Science — Computer Software Engineering",
    period: "2017 — 2019",
    highlight: true,
  },
  {
    institution: "John Naisbitt University, Faculty of Business Studies",
    degree: "Bachelor's Degree — Business / Managerial Economics",
    period: "2002 — 2007",
    highlight: false,
  },
];
---

<section id="education" class="py-24 md:py-32 px-6">
  <div class="mx-auto max-w-4xl">
    <div class="reveal">
      <p class="font-mono text-accent text-sm mb-2">04. Education</p>
      <h2 class="text-3xl md:text-4xl font-bold text-text-heading mb-12">
        Academic background
      </h2>
    </div>

    <div class="reveal grid sm:grid-cols-2 gap-6">
      {education.map((edu) => (
        <div
          class:list={[
            "rounded-xl border p-6 transition-colors duration-200",
            edu.highlight
              ? "border-accent/30 bg-bg-card hover:bg-bg-card-hover"
              : "border-border bg-bg-card hover:bg-bg-card-hover",
          ]}
        >
          <div class="flex items-start gap-3 mb-3">
            <div
              class:list={[
                "flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center mt-0.5",
                edu.highlight ? "bg-accent/10" : "bg-bg",
              ]}
            >
              <svg
                class:list={[
                  "w-5 h-5",
                  edu.highlight ? "text-accent" : "text-text-muted",
                ]}
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 14l9-5-9-5-9 5 9 5z"
                />
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"
                />
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 14l9-5-9-5-9 5 9 5zM12 14v7m9-11.5V17"
                />
              </svg>
            </div>
            <div>
              <h3 class="text-base font-bold text-text-heading leading-tight">{edu.institution}</h3>
              <p class="text-accent text-sm font-medium mt-1">{edu.degree}</p>
              <p class="font-mono text-xs text-text-muted/60 mt-1">{edu.period}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
