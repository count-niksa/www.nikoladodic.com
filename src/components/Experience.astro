---
const jobs = [
  {
    company: "Voice Systems Engineering",
    role: "Tech Team Lead Software Developer",
    period: "Sep 2023 — Present",
    location: "Pennsylvania, US",
    tags: ["C#", ".NET", "Azure", "SQL Server", "Team Lead"],
    bullets: [
      "Lead a development team delivering enterprise voice and communications platform software",
      "Drive architecture decisions, establish code quality standards, and own technical direction",
      "Design and implement features in C#/.NET with Azure cloud services and SQL Server backends",
      "Conduct code reviews, mentor developers, and define sprint planning and delivery workflows",
    ],
    highlight: true,
  },
  {
    company: "Voice Systems Engineering, Inc.",
    role: "Senior Software Developer",
    period: "Aug 2020 — Sep 2023",
    location: "Philadelphia, PA",
    tags: ["C#", "ASP.NET", "Azure", "SQL Server", "REST APIs"],
    bullets: [
      "Designed and built core platform modules in C#/ASP.NET deployed on Azure infrastructure",
      "Owned features end-to-end: requirements gathering, database design, API development, deployment",
      "Worked extensively with Microsoft SQL Server — schema design, stored procedures, performance tuning",
      "Promoted to team lead based on consistent delivery and technical ownership",
    ],
  },
  {
    company: "Sobot Software",
    role: "Software Developer → Senior Developer Team Lead",
    period: "Jul 2018 — Jun 2020",
    location: "Belgrade, Serbia",
    tags: ["C#", ".NET", "SQL Server", "Agile", "Team Lead"],
    bullets: [
      "Promoted from developer to team lead within 8 months — managed a team shipping client-facing products",
      "Built and maintained .NET applications with SQL Server data layers",
      "Balanced hands-on development with team management, code reviews, and sprint coordination",
    ],
  },
  {
    company: "Intelisale",
    role: "Software Developer",
    period: "Mar 2017 — Jul 2018",
    location: "Belgrade, Serbia",
    tags: ["C#", ".NET", "SQL Server"],
    bullets: [
      "Developed features for a B2B sales intelligence platform in C#/.NET",
      "Worked across the stack — backend services, database queries, and API integrations",
    ],
  },
  {
    company: "Earlier Career",
    role: "Systems Engineer · Freelance Developer · Emirates Airline",
    period: "2008 — 2017",
    location: "Belgrade · Dubai · Remote",
    tags: ["Systems Engineering", "Freelance", "International"],
    bullets: [
      "Systems engineering at Saga d.o.o. — infrastructure and deployment",
      "Freelance .NET development on Upwork while transitioning into software full-time",
      "3+ years at Emirates Airline (Business Class) — built communication, discipline, and global perspective",
    ],
  },
];
---

<section id="experience" class="py-24 md:py-32 px-6">
  <div class="mx-auto max-w-4xl">
    <div class="reveal">
      <p class="font-mono text-accent text-sm mb-2">02. Experience</p>
      <h2 class="text-3xl md:text-4xl font-bold text-text-heading mb-12">
        Where I've worked
      </h2>
    </div>

    <div class="relative">
      <!-- Timeline line -->
      <div
        class="absolute left-[7px] top-2 bottom-2 w-px bg-gradient-to-b from-accent via-accent-secondary to-border"
      ></div>

      <div class="space-y-10">
        {jobs.map((job) => (
          <div class="reveal relative pl-10">
            {/* Timeline dot */}
            <div
              class:list={[
                "absolute left-0 top-2 w-[15px] h-[15px] rounded-full border-2",
                job.highlight
                  ? "border-accent bg-accent/20 shadow-[0_0_12px_var(--color-accent-glow)]"
                  : "border-border bg-bg-card",
              ]}
            />

            <div
              class:list={[
                "rounded-xl border p-6 transition-colors duration-200",
                job.highlight
                  ? "border-accent/30 bg-bg-card hover:bg-bg-card-hover"
                  : "border-border bg-bg-card hover:bg-bg-card-hover",
              ]}
            >
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-1">
                <h3 class="text-lg font-bold text-text-heading">{job.company}</h3>
                <span class="font-mono text-xs text-text-muted">{job.period}</span>
              </div>
              <p class="text-accent font-medium text-sm mb-2">{job.role}</p>
              <p class="font-mono text-xs text-text-muted/60 mb-3">{job.location}</p>

              <ul class="space-y-1.5 mb-4">
                {job.bullets.map((bullet) => (
                  <li class="flex items-start gap-2 text-text-muted text-sm leading-relaxed">
                    <span class="text-accent mt-1 text-xs">&#9656;</span>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>

              <div class="flex flex-wrap gap-1.5">
                {job.tags.map((tag) => (
                  <span class="rounded border border-border bg-bg px-2 py-0.5 text-[11px] font-mono text-accent/80">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
