---
const categories = [
  {
    title: "Languages & Frameworks",
    icon: "{ }",
    skills: [
      { name: "C#", level: "primary" },
      { name: ".NET / .NET Core", level: "primary" },
      { name: "ASP.NET", level: "primary" },
      { name: "Entity Framework", level: "primary" },
      { name: "JavaScript", level: "secondary" },
      { name: "TypeScript", level: "secondary" },
      { name: "Python", level: "secondary" },
    ],
  },
  {
    title: "Cloud & Infrastructure",
    icon: ">>>",
    skills: [
      { name: "Microsoft Azure", level: "primary" },
      { name: "Azure DevOps", level: "primary" },
      { name: "CI/CD Pipelines", level: "primary" },
      { name: "REST API Design", level: "primary" },
      { name: "IIS", level: "secondary" },
      { name: "Docker", level: "secondary" },
      { name: "Microservices", level: "secondary" },
    ],
  },
  {
    title: "Data & Storage",
    icon: "[ ]",
    skills: [
      { name: "Microsoft SQL Server", level: "primary" },
      { name: "T-SQL", level: "primary" },
      { name: "Database Design", level: "primary" },
      { name: "Stored Procedures", level: "primary" },
      { name: "Performance Tuning", level: "secondary" },
      { name: "Query Optimization", level: "secondary" },
    ],
  },
  {
    title: "Engineering Practices",
    icon: " > ",
    skills: [
      { name: "System Design", level: "primary" },
      { name: "Code Review", level: "primary" },
      { name: "Agile / Scrum", level: "primary" },
      { name: "Team Leadership", level: "primary" },
      { name: "Mentoring", level: "secondary" },
      { name: "Technical Planning", level: "secondary" },
    ],
  },
];
---

<section id="skills" class="py-24 md:py-32 px-6">
  <div class="mx-auto max-w-4xl">
    <div class="reveal">
      <p class="font-mono text-accent text-sm mb-2">03. Skills</p>
      <h2 class="text-3xl md:text-4xl font-bold text-text-heading mb-12">
        Technical toolkit
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      {categories.map((cat) => (
        <div class="reveal rounded-xl border border-border bg-bg-card p-6 hover:border-accent/30 transition-colors duration-200">
          <div class="flex items-center gap-3 mb-5">
            <span class="font-mono text-accent text-sm bg-accent/10 px-2 py-1 rounded">
              {cat.icon}
            </span>
            <h3 class="text-base font-bold text-text-heading">{cat.title}</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {cat.skills.map((skill) => (
              <span
                class:list={[
                  "rounded-md border px-3 py-1.5 text-xs font-mono transition-colors duration-200",
                  skill.level === "primary"
                    ? "border-accent/30 bg-accent/5 text-accent hover:bg-accent/10"
                    : "border-border bg-bg text-text-muted hover:border-accent/50 hover:text-accent",
                ]}
              >
                {skill.name}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
