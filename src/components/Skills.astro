---
const categories = [
  {
    title: "Languages & Frameworks",
    icon: "{ }",
    skills: ["C#", ".NET / .NET Core", "ASP.NET", "Entity Framework", "Python", "JavaScript", "TypeScript"],
  },
  {
    title: "Cloud & Infrastructure",
    icon: ">>>",
    skills: ["Microsoft Azure", "Azure DevOps", "CI/CD Pipelines", "Docker", "IIS", "REST APIs", "Microservices"],
  },
  {
    title: "Data & Storage",
    icon: "[ ]",
    skills: ["Microsoft SQL Server", "T-SQL", "Database Design", "Performance Tuning", "Redis", "NoSQL"],
  },
  {
    title: "Leadership & Process",
    icon: " > ",
    skills: ["Team Leadership", "Code Review", "Agile / Scrum", "System Design", "Mentoring", "Technical Planning"],
  },
];
---

<section id="skills" class="py-24 md:py-32 px-6">
  <div class="mx-auto max-w-4xl">
    <div class="reveal">
      <p class="font-mono text-accent text-sm mb-2">03. Skills</p>
      <h2 class="text-3xl md:text-4xl font-bold text-text-heading mb-12">
        What I work with
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      {categories.map((cat) => (
        <div class="reveal rounded-xl border border-border bg-bg-card p-6 hover:border-accent/30 transition-colors duration-200">
          <div class="flex items-center gap-3 mb-5">
            <span class="font-mono text-accent text-sm bg-accent/10 px-2 py-1 rounded">
              {cat.icon}
            </span>
            <h3 class="text-base font-bold text-text-heading">{cat.title}</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {cat.skills.map((skill) => (
              <span class="rounded-md border border-border bg-bg px-3 py-1.5 text-xs font-mono text-text-muted hover:border-accent/50 hover:text-accent transition-colors duration-200">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
